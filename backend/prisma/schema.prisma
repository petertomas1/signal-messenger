datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

generator client {
  provider = "prisma-client-js"
}

model User {
  id        String   @id @default(cuid())
  username  String   @unique
  email     String   @unique
  createdAt DateTime @default(now())
  messages  Message[]
  groups    Group[]
}

model Message {
  id        String   @id @default(cuid())
  content   String
  senderId  String
  chatId    String
  createdAt DateTime @default(now())
  sender    User     @relation(fields: [senderId], references: [id])
}

model Group {
  id        String   @id @default(cuid())
  name      String
  members   User[]
}